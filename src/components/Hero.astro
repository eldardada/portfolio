---
import { profile } from "../data/content";
import CopyEmail from "./CopyEmail.tsx";

const email = "eldar.dadashov16@gmail.com";
---

<section class="hero">
  <div class="inner">
    <p class="eyebrow">{profile.role} · {profile.yearsExperience} years in production</p>
    <h1>{profile.name}</h1>
    <p class="tagline">{profile.tagline}</p>

    <ul class="stack" aria-label="Core stack">
      {profile.stack.map((tech) => <li>{tech}</li>)}
    </ul>

    <p class="availability">{profile.availability}</p>

    <div class="cta">
      <a class="btn primary" href="/cv.pdf" download>Download CV</a>
      <a class="btn" href={`mailto:${email}`}>Get in touch</a>
      <CopyEmail client:visible email={email} />
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: grid;
    place-items: center;
    padding: 2rem;
  }
  .inner {
    width: 100%;
    max-width: 820px;
  }
  .eyebrow {
    font-family: var(--mono);
    color: var(--accent);
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    margin-bottom: 1rem;
  }
  h1 {
    font-size: clamp(2.5rem, 8vw, 5rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
    font-weight: 800;
  }
  .tagline {
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    color: var(--text-dim);
    margin-top: 1.25rem;
    max-width: 34ch;
  }
  .stack {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 2rem;
  }
  .stack li {
    font-family: var(--mono);
    font-size: 0.85rem;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    padding: 0.35rem 0.7rem;
    border-radius: 6px;
  }
  .availability {
    margin-top: 2rem;
    color: var(--text-dim);
    font-size: 0.95rem;
  }
  .cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }
  .btn {
    font-family: var(--mono);
    font-size: 0.9rem;
    padding: 0.65rem 1.1rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    transition: border-color 0.2s, transform 0.2s;
  }
  .btn:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .btn.primary {
    background: var(--accent);
    color: #04110f;
    border-color: var(--accent);
    font-weight: 600;
  }
  .btn.primary:hover {
    filter: brightness(1.08);
  }
</style>
