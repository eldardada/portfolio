---
import Base from "../layouts/Base.astro";
import { profile } from "../data/content";

const eyebrow = `${profile.role}  /  ${profile.yearsExperience} years in production`;
---

<Base title={`${profile.name} · ${profile.role}`}>
  <div id="ed-portfolio" style="background:var(--bg);color:var(--text);font-family:'Hanken Grotesk',sans-serif;min-height:100vh;position:relative;overflow-x:hidden">
    <canvas id="hero-canvas" style="position:fixed;inset:0;width:100%;height:100%;z-index:0;pointer-events:none"></canvas>
    <div style="position:relative;z-index:1">

    <nav style="position:fixed;top:0;left:0;right:0;z-index:60;display:flex;align-items:center;justify-content:space-between;padding:22px clamp(20px,4vw,44px);font-family:'JetBrains Mono',monospace">
      <a href="#hero" data-magnetic style="display:flex;align-items:center;gap:9px;font-size:13px;letter-spacing:.06em;color:var(--text)">
        <span style="width:7px;height:7px;border-radius:50%;background:var(--accent);display:inline-block"></span>ELDAR DADASHOV
      </a>
      <div style="display:flex;align-items:center;gap:clamp(16px,2.4vw,30px);font-size:12.5px;letter-spacing:.08em;color:var(--dim)">
        <a href="#about" data-magnetic class="nav-link">ABOUT</a>
        <a href="#skills" data-magnetic class="nav-link">SKILLS</a>
        <a href="#work" data-magnetic class="nav-link">WORK</a>
        <a href="#contact" data-magnetic class="nav-link">CONTACT</a>
        <button type="button" data-theme-toggle data-magnetic class="theme-toggle" aria-label="Switch theme"></button>
      </div>
    </nav>

    <section id="hero" style="position:relative;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:120px clamp(20px,5vw,40px) 90px;overflow:hidden">
      <div style="position:relative;z-index:2;display:flex;flex-direction:column;align-items:center">
        <div style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:.18em;color:var(--accent);text-transform:uppercase">{eyebrow}</div>
        <h1 id="hero-name" style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:clamp(56px,14.5vw,186px);line-height:0.88;letter-spacing:-0.04em;color:var(--text);margin:20px 0 28px;transition:opacity 1s cubic-bezier(.16,1,.3,1)">ELDAR<br />DADASHOV</h1>
        <p style="font-family:'Hanken Grotesk',sans-serif;font-weight:400;font-size:clamp(18px,2vw,24px);line-height:1.45;color:var(--text);max-width:30ch">{profile.tagline}</p>
        <div style="font-family:'JetBrains Mono',monospace;font-size:12.5px;letter-spacing:.06em;color:var(--dim);margin-top:20px;max-width:46ch;line-height:1.9">{profile.heroStack}</div>
        <div style="display:flex;gap:14px;margin-top:34px;flex-wrap:wrap;justify-content:center">
          <a href="#contact" data-magnetic class="btn-primary" style="font-family:'Hanken Grotesk',sans-serif;font-weight:600;font-size:15px;background:var(--accent);color:var(--on-accent);padding:15px 26px;border-radius:3px;white-space:nowrap">Get in touch</a>
          <a href="/cv.pdf" download data-magnetic class="btn-outline" style="font-family:'Hanken Grotesk',sans-serif;font-weight:500;font-size:15px;color:var(--text);padding:15px 26px;border-radius:3px;border:1px solid var(--line);white-space:nowrap">Download CV</a>
        </div>
      </div>
      <div style="position:absolute;bottom:26px;left:50%;transform:translateX(-50%);z-index:2;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.2em;color:var(--dim)">( SCROLL )</div>
    </section>

    <div class="marquee" aria-hidden="true" style="border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:clamp(26px,4vh,46px) 0">
      <div class="marquee__track">
        <span class="marquee__item">Vue</span><span class="marquee__item">TypeScript</span><span class="marquee__item">React</span><span class="marquee__item">Node.js</span><span class="marquee__item">NestJS</span><span class="marquee__item">PHP</span><span class="marquee__item">Symfony</span><span class="marquee__item">PostgreSQL</span><span class="marquee__item">Redis</span><span class="marquee__item">BullMQ</span><span class="marquee__item">Next.js</span><span class="marquee__item">Drizzle</span><span class="marquee__item">Docker</span><span class="marquee__item">Playwright</span>
      </div>
      <div class="marquee__track">
        <span class="marquee__item">Vue</span><span class="marquee__item">TypeScript</span><span class="marquee__item">React</span><span class="marquee__item">Node.js</span><span class="marquee__item">NestJS</span><span class="marquee__item">PHP</span><span class="marquee__item">Symfony</span><span class="marquee__item">PostgreSQL</span><span class="marquee__item">Redis</span><span class="marquee__item">BullMQ</span><span class="marquee__item">Next.js</span><span class="marquee__item">Drizzle</span><span class="marquee__item">Docker</span><span class="marquee__item">Playwright</span>
      </div>
    </div>

    <section id="about" style="max-width:1120px;margin:0 auto;padding:clamp(90px,13vh,170px) clamp(20px,5vw,40px);position:relative">
      <div data-reveal style="display:grid;grid-template-columns:minmax(0,200px) 1fr;gap:clamp(24px,5vw,72px);align-items:start">
        <div style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:.14em;color:var(--accent);padding-top:10px">/ about</div>
        <div>
          <h2 data-words style="font-family:'Bricolage Grotesque',sans-serif;font-weight:600;font-size:clamp(28px,4.2vw,52px);line-height:1.08;letter-spacing:-0.02em;color:var(--text);max-width:18ch">I build the whole thing.</h2>
          <p style="font-family:'Hanken Grotesk',sans-serif;font-size:clamp(17px,1.5vw,21px);line-height:1.65;color:var(--dim);max-width:60ch;margin-top:26px">Six years in, I move comfortably from schema design and API internals up to the pixels a user actually touches, and I care about both equally. I am strongest end to end. I have a soft spot for Vue, and I gravitate toward work where the hard part is real.</p>
          <p style="font-family:'Hanken Grotesk',sans-serif;font-size:clamp(17px,1.5vw,21px);line-height:1.65;color:var(--dim);max-width:60ch;margin-top:18px">Open to remote roles worldwide, and ready to relocate within the EU.</p>
        </div>
      </div>
    </section>

    <section id="skills" style="max-width:1120px;margin:0 auto;padding:clamp(70px,9vh,120px) clamp(20px,5vw,40px);position:relative">
      <div data-reveal style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:.14em;color:var(--accent);margin-bottom:36px">/ skills</div>

      <div data-reveal style="display:grid;grid-template-columns:minmax(0,200px) 1fr;gap:clamp(20px,4vw,56px);align-items:baseline;border-top:1px solid var(--line);padding:30px 0">
        <div style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:.1em;color:var(--dim);text-transform:uppercase">Frontend</div>
        <div style="display:flex;flex-wrap:wrap;gap:14px 30px">
          <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(20px,2.4vw,30px);color:var(--text)">Vue 3</span>
          <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(20px,2.4vw,30px);color:var(--text)">React</span>
          <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(20px,2.4vw,30px);color:var(--text)">Next.js</span>
          <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(20px,2.4vw,30px);color:var(--text)">TypeScript</span>
          <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(20px,2.4vw,30px);color:var(--text)">Vite</span>
        </div>
      </div>

      <div data-reveal style="display:grid;grid-template-columns:minmax(0,200px) 1fr;gap:clamp(20px,4vw,56px);align-items:baseline;border-top:1px solid var(--line);padding:30px 0">
        <div style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:.1em;color:var(--dim);text-transform:uppercase">Backend</div>
        <div style="display:flex;flex-wrap:wrap;gap:14px 30px">
          <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(20px,2.4vw,30px);color:var(--text)">Node.js</span>
          <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(20px,2.4vw,30px);color:var(--text)">NestJS</span>
          <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(20px,2.4vw,30px);color:var(--text)">PHP</span>
          <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(20px,2.4vw,30px);color:var(--text)">Symfony</span>
          <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(20px,2.4vw,30px);color:var(--text)">Laravel</span>
        </div>
      </div>

      <div data-reveal style="display:grid;grid-template-columns:minmax(0,200px) 1fr;gap:clamp(20px,4vw,56px);align-items:baseline;border-top:1px solid var(--line);padding:30px 0">
        <div style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:.1em;color:var(--dim);text-transform:uppercase">Data</div>
        <div style="display:flex;flex-wrap:wrap;gap:14px 30px">
          <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(20px,2.4vw,30px);color:var(--text)">PostgreSQL</span>
          <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(20px,2.4vw,30px);color:var(--text)">Redis</span>
          <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(20px,2.4vw,30px);color:var(--text)">Prisma</span>
          <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(20px,2.4vw,30px);color:var(--text)">Drizzle</span>
        </div>
      </div>

      <div data-reveal style="display:grid;grid-template-columns:minmax(0,200px) 1fr;gap:clamp(20px,4vw,56px);align-items:baseline;border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:30px 0">
        <div style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:.1em;color:var(--dim);text-transform:uppercase">Infra</div>
        <div style="display:flex;flex-wrap:wrap;gap:14px 30px">
          <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(20px,2.4vw,30px);color:var(--text)">Docker</span>
          <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(20px,2.4vw,30px);color:var(--text)">AWS</span>
          <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(20px,2.4vw,30px);color:var(--text)">GitLab CI/CD</span>
          <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(20px,2.4vw,30px);color:var(--text)">Playwright</span>
        </div>
      </div>
    </section>

    <section id="experience" style="max-width:1120px;margin:0 auto;padding:clamp(70px,11vh,150px) clamp(20px,5vw,40px);position:relative">
      <div data-reveal style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:.14em;color:var(--accent);margin-bottom:14px">/ experience</div>
      <h2 data-words style="font-family:'Bricolage Grotesque',sans-serif;font-weight:600;font-size:clamp(28px,4.2vw,52px);line-height:1.06;letter-spacing:-0.02em;color:var(--text);max-width:16ch;margin-bottom:54px">Work that moved a number.</h2>

      <div style="display:flex;flex-direction:column;gap:6px">
        <div data-reveal style="border-left:1px solid var(--line);padding:8px 0 40px 30px;position:relative">
          <span style="position:absolute;left:-5.5px;top:14px;width:10px;height:10px;border-radius:50%;background:var(--accent)"></span>
          <div style="font-family:'JetBrains Mono',monospace;font-size:12.5px;letter-spacing:.1em;color:var(--dim);text-transform:uppercase">Video platform · 50,000 users</div>
          <h3 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:600;font-size:clamp(22px,2.6vw,32px);color:var(--text);margin:10px 0 12px">Frontend at scale</h3>
          <p style="font-family:'Hanken Grotesk',sans-serif;font-size:clamp(16px,1.4vw,19px);line-height:1.62;color:var(--dim);max-width:62ch">Led the Vue 2 to 3 migration across <span style="color:var(--accent)">2,500 plus components</span> without freezing feature work. Rebuilt the toolchain on Vite and took the production build from <span style="color:var(--accent)">10 minutes to 30 seconds</span>, so the whole team shipped faster every single day.</p>
        </div>
        <div data-reveal style="border-left:1px solid var(--line);padding:8px 0 40px 30px;position:relative">
          <span style="position:absolute;left:-5.5px;top:14px;width:10px;height:10px;border-radius:50%;background:var(--accent)"></span>
          <div style="font-family:'JetBrains Mono',monospace;font-size:12.5px;letter-spacing:.1em;color:var(--dim);text-transform:uppercase">Automation platforms · end to end</div>
          <h3 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:600;font-size:clamp(22px,2.6vw,32px);color:var(--text);margin:10px 0 12px">Built two from zero</h3>
          <p style="font-family:'Hanken Grotesk',sans-serif;font-size:clamp(16px,1.4vw,19px);line-height:1.62;color:var(--dim);max-width:62ch">Designed and shipped <span style="color:var(--accent)">two production automation platforms</span> on NestJS, React and Electron. Owned the data model, the services and the desktop client. Same hands from the first migration to the first deploy.</p>
        </div>
        <div data-reveal style="border-left:1px solid var(--line);padding:8px 0 8px 30px;position:relative">
          <span style="position:absolute;left:-5.5px;top:14px;width:10px;height:10px;border-radius:50%;background:var(--accent)"></span>
          <div style="font-family:'JetBrains Mono',monospace;font-size:12.5px;letter-spacing:.1em;color:var(--dim);text-transform:uppercase">Across the stack · 6 years</div>
          <h3 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:600;font-size:clamp(22px,2.6vw,32px);color:var(--text);margin:10px 0 12px">Whatever the product needed</h3>
          <p style="font-family:'Hanken Grotesk',sans-serif;font-size:clamp(16px,1.4vw,19px);line-height:1.62;color:var(--dim);max-width:62ch">PHP, Symfony and Laravel services, Postgres schemas under real load, CI pipelines, and the interfaces sitting on top of all of it. The constant has been owning a feature from request to render.</p>
        </div>
      </div>
    </section>

    <section id="work" style="max-width:1120px;margin:0 auto;padding:clamp(70px,9vh,130px) clamp(20px,5vw,40px);position:relative">
      <div data-reveal style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:.14em;color:var(--accent);margin-bottom:14px">/ selected work</div>
      <h2 data-words style="font-family:'Bricolage Grotesque',sans-serif;font-weight:600;font-size:clamp(28px,4.2vw,52px);line-height:1.06;letter-spacing:-0.02em;color:var(--text);max-width:16ch;margin-bottom:48px">A few things I shipped.</h2>

      <a href="/work/valt" data-reveal class="featured-case" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,300px),1fr));background:var(--surface);border-radius:7px;overflow:hidden;color:inherit;margin-bottom:26px">
        <div style="padding:clamp(28px,4vw,46px);display:flex;flex-direction:column;justify-content:center">
          <div style="font-family:'JetBrains Mono',monospace;font-size:11.5px;letter-spacing:.14em;color:var(--accent);text-transform:uppercase">Featured case study</div>
          <h3 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:clamp(38px,6vw,68px);line-height:0.95;letter-spacing:-0.03em;margin:10px 0 14px">VALT</h3>
          <p style="font-family:'Hanken Grotesk',sans-serif;font-size:clamp(15px,1.4vw,18px);line-height:1.55;color:var(--dim);max-width:48ch">Enterprise video capture and evidence management used by 770+ organizations and 50,000+ users. I led it for four years as the lead developer, across Vue and Symfony, down to the Java streaming layer.</p>
          <div style="display:flex;flex-wrap:wrap;gap:18px 32px;margin-top:24px">
            <div style="display:flex;align-items:baseline;gap:7px"><span class="stat-v" style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:22px;color:var(--text)">50,000+</span><span style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--dim);text-transform:uppercase">users</span></div>
            <div style="display:flex;align-items:baseline;gap:7px"><span class="stat-v" style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:22px;color:var(--text)">770+</span><span style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--dim);text-transform:uppercase">orgs</span></div>
            <div style="display:flex;align-items:baseline;gap:7px"><span class="stat-v" style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:22px;color:var(--text)">2,500+</span><span style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--dim);text-transform:uppercase">components</span></div>
          </div>
          <div class="case-cta" style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:.06em;color:var(--text);margin-top:28px">Read the case study →</div>
        </div>
        <div style="position:relative;min-height:240px;overflow:hidden;border-left:1px solid var(--line);background:var(--img-well);display:flex;align-items:center;justify-content:center;padding:clamp(22px,3.5vw,44px)">
          <div aria-hidden="true" style="position:absolute;inset:0;background:radial-gradient(62% 58% at 50% 38%, var(--glow), transparent 70%);pointer-events:none"></div>
          <div style="position:relative;width:100%;max-width:560px;border:1px solid var(--line);border-radius:9px;overflow:hidden;box-shadow:0 26px 46px var(--shadow-color)">
            <img src="/projects/valt/cover.png" alt="VALT platform interface" loading="lazy" style="display:block;width:100%;height:auto" />
          </div>
        </div>
      </a>

      <a href="/work/massposting" data-reveal class="featured-case" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,300px),1fr));background:var(--surface);border-radius:7px;overflow:hidden;color:inherit;margin-bottom:26px">
        <div style="position:relative;min-height:240px;overflow:hidden;border-right:1px solid var(--line);background:var(--img-well);display:flex;align-items:center;justify-content:center;padding:clamp(22px,3.5vw,44px)">
          <div aria-hidden="true" style="position:absolute;inset:0;background:radial-gradient(62% 58% at 50% 38%, var(--glow), transparent 70%);pointer-events:none"></div>
          <div style="position:relative;width:100%;max-width:560px;border:1px solid var(--line);border-radius:9px;overflow:hidden;box-shadow:0 26px 46px var(--shadow-color)">
            <img src="/projects/massposting/accounts.png" alt="Massposting accounts dashboard" loading="lazy" style="display:block;width:100%;height:auto" />
          </div>
        </div>
        <div style="padding:clamp(28px,4vw,46px);display:flex;flex-direction:column;justify-content:center">
          <div style="font-family:'JetBrains Mono',monospace;font-size:11.5px;letter-spacing:.14em;color:var(--accent);text-transform:uppercase">Featured case study</div>
          <h3 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:clamp(34px,5vw,60px);line-height:0.98;letter-spacing:-0.03em;margin:10px 0 14px">Massposting</h3>
          <p style="font-family:'Hanken Grotesk',sans-serif;font-size:clamp(15px,1.4vw,18px);line-height:1.55;color:var(--dim);max-width:48ch">A multi-tenant SMM automation platform: cross-posting across ~1,000 accounts, marketplace attribution and analytics, plus AI video generation. I built the whole thing solo, on NestJS and Next.js.</p>
          <div style="display:flex;flex-wrap:wrap;gap:18px 32px;margin-top:24px">
            <div style="display:flex;align-items:baseline;gap:7px"><span class="stat-v" style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:22px;color:var(--text)">Solo</span><span style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--dim);text-transform:uppercase">end to end</span></div>
            <div style="display:flex;align-items:baseline;gap:7px"><span class="stat-v" style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:22px;color:var(--text)">3</span><span style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--dim);text-transform:uppercase">marketplaces</span></div>
            <div style="display:flex;align-items:baseline;gap:7px"><span class="stat-v" style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:22px;color:var(--text)">~1,000</span><span style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--dim);text-transform:uppercase">accounts</span></div>
          </div>
          <div class="case-cta" style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:.06em;color:var(--text);margin-top:28px">Read the case study →</div>
        </div>
      </a>

      <a href="/work/umnogor" data-reveal class="featured-case" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,300px),1fr));background:var(--surface);border-radius:7px;overflow:hidden;color:inherit;margin-bottom:26px">
        <div style="padding:clamp(28px,4vw,46px);display:flex;flex-direction:column;justify-content:center">
          <div style="font-family:'JetBrains Mono',monospace;font-size:11.5px;letter-spacing:.14em;color:var(--accent);text-transform:uppercase">Case study · Matriks 2021</div>
          <h3 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:clamp(34px,5vw,60px);line-height:0.98;letter-spacing:-0.03em;margin:10px 0 14px">Umnogor</h3>
