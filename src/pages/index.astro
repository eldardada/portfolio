  <script is:inline>
    class Portfolio {
      mount() {
        this.root = document.getElementById('ed-portfolio');
        if (!this.root) return;
        this.raf = 0;
        this.disposers = [];
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        this.coarse = window.matchMedia('(pointer:coarse)').matches;

        this.amber = this.parseColor('#FA8927');
        this.density = 'Balanced';
        this.idleOn = true;

        if (reduce) { this.bindAnchorsFallback(); return; }

        this.setupReveals();
        this.setupWordStagger();
        this.initCursor();
        this.initTilt();
        this.initMagnetic();
        this.initFeatured();
        this.initCountUp();

        this.poll(() => window.Lenis, 8000).then(() => this.initScroll()).catch(() => this.bindAnchorsFallback());
        this.whenReady().then(() => this.initParticles()).catch((e) => console.warn('[hero] static fallback:', e && e.message));
      }

      poll(test, timeout) {
        return new Promise((res, rej) => {
          const t0 = Date.now();
          const id = setInterval(() => {
            let v; try { v = test(); } catch (e) { v = null; }
            if (v) { clearInterval(id); res(v); }
            else if (Date.now() - t0 > timeout) { clearInterval(id); rej(new Error('timeout')); }
          }, 50);
        });
      }
      whenReady() {
        return this.poll(() => window.THREE, 10000).then(() => (document.fonts ? document.fonts.ready : Promise.resolve()));
      }
      parseColor(str) {
        const c = document.createElement('canvas'); c.width = c.height = 1;
        const x = c.getContext('2d'); x.fillStyle = '#000'; x.fillStyle = str;
        x.fillRect(0, 0, 1, 1);
        const d = x.getImageData(0, 0, 1, 1).data;
        return [d[0] / 255, d[1] / 255, d[2] / 255];
      }

      setupReveals() {
        const els = Array.from(this.root.querySelectorAll('[data-reveal]'));
        els.forEach((el) => {
          el.style.opacity = '0';
          el.style.transform = 'translateY(30px)';
          el.style.clipPath = 'inset(-2px -2px 100% -2px)';
          el.style.willChange = 'transform, opacity, clip-path';
          el.style.transition = 'clip-path .95s cubic-bezier(.16,1,.3,1), transform .95s cubic-bezier(.16,1,.3,1), opacity .7s ease-out';
        });
        // The hidden state clips each block to zero height. Chromium folds
        // clip-path into the area an IntersectionObserver measures, so an IO would
        // see these as permanently non-intersecting and never reveal them — the
        // whole page would stay invisible (Firefox ignores clip-path in IO, which
        // is why it looked fine there). Drive the reveal from scroll geometry via
        // getBoundingClientRect instead; it is unaffected by clip-path.
        const reveal = (el) => {
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
          el.style.clipPath = 'inset(-2px -2px -2px -2px)';
        };
        let pending = els.slice();
        const cleanup = () => {
          window.removeEventListener('scroll', check);
          window.removeEventListener('resize', check);
        };
        const check = () => {
          if (!pending.length) return;
          const h = window.innerHeight;
          pending = pending.filter((el) => {
            const r = el.getBoundingClientRect();
            if (r.top < h * 0.93 && r.bottom > 0) { reveal(el); return false; }
            return true;
          });
          if (!pending.length) cleanup();
        };
        window.addEventListener('scroll', check, { passive: true });
        window.addEventListener('resize', check);
        this.disposers.push(cleanup);
        check();
        requestAnimationFrame(check);
        setTimeout(check, 300);
      }

      setupWordStagger() {
        const heads = Array.from(this.root.querySelectorAll('[data-words]'));
        heads.forEach((h) => {
          const words = h.textContent.trim().split(/\s+/);
          h.textContent = '';
          h.style.display = 'block';
          words.forEach((w, i) => {
            const wrap = document.createElement('span');
            wrap.style.display = 'inline-block';
            wrap.style.overflow = 'hidden';
            wrap.style.verticalAlign = 'top';
            wrap.style.paddingBottom = '0.08em';
            const inner = document.createElement('span');
            inner.style.display = 'inline-block';
            inner.style.transform = 'translateY(112%)';
            inner.style.transition = 'transform .85s cubic-bezier(.16,1,.3,1)';
            inner.style.transitionDelay = (i * 0.06) + 's';
            inner.textContent = w;
            wrap.appendChild(inner);
            h.appendChild(wrap);
            if (i < words.length - 1) h.appendChild(document.createTextNode(' '));
          });
        });
        const io = new IntersectionObserver((ents) => {
          ents.forEach((en) => {
            if (en.isIntersecting) {
              en.target.querySelectorAll('span > span').forEach((s) => { s.style.transform = 'translateY(0)'; });
              io.unobserve(en.target);
            }
          });
        }, { threshold: 0.3 });
        heads.forEach((h) => io.observe(h));
        this.disposers.push(() => io.disconnect());
      }

      initScroll() {
        const Lenis = window.Lenis;
        const lenis = new Lenis({ lerp: 0.085, smoothWheel: true, wheelMultiplier: 1 });
        this.lenis = lenis;
        const raf = (t) => { lenis.raf(t); this._sraf = requestAnimationFrame(raf); };
        this._sraf = requestAnimationFrame(raf);
        this.disposers.push(() => cancelAnimationFrame(this._sraf));
        this.bindAnchors((el) => lenis.scrollTo(el, { offset: -10, duration: 1.1 }));
      }
      bindAnchorsFallback() {
        this.bindAnchors((el) => {
          const top = el.getBoundingClientRect().top + window.scrollY - 10;
          window.scrollTo({ top, behavior: 'smooth' });
        });
      }
      bindAnchors(go) {
        this.root.querySelectorAll('a[href^="#"]').forEach((a) => {
          a.addEventListener('click', (e) => {
            const id = a.getAttribute('href');
            if (id.length > 1) {
              const el = this.root.querySelector(id);
              if (el) { e.preventDefault(); go(el); }
            }
          });
        });
      }

      initCursor() {
        if (this.coarse) return;
        const dot = this.root.querySelector('#cursor-dot');
        const ring = this.root.querySelector('#cursor-ring');
        if (!dot || !ring) return;
        this.root.style.cursor = 'none';
        let mx = innerWidth / 2, my = innerHeight / 2, rx = mx, ry = my;
        const onMove = (e) => {
          mx = e.clientX; my = e.clientY;
          dot.style.opacity = '1'; ring.style.opacity = '0.55';
          dot.style.transform = 'translate(' + mx + 'px,' + my + 'px) translate(-50%,-50%)';
        };
        window.addEventListener('mousemove', onMove);
        const loop = () => {
          rx += (mx - rx) * 0.18; ry += (my - ry) * 0.18;
          ring.style.transform = 'translate(' + rx + 'px,' + ry + 'px) translate(-50%,-50%)';
          this._craf = requestAnimationFrame(loop);
        };
        loop();
        this.root.querySelectorAll('a:not(.featured-case),button,[data-magnetic],[data-tilt]').forEach((el) => {
          el.addEventListener('mouseenter', () => { ring.style.width = '58px'; ring.style.height = '58px'; ring.style.opacity = '0.9'; });
          el.addEventListener('mouseleave', () => { ring.style.width = '30px'; ring.style.height = '30px'; ring.style.opacity = '0.55'; });
        });
        const label = this.root.querySelector('#cursor-label');
        this.root.querySelectorAll('.featured-case').forEach((el) => {
          el.addEventListener('mouseenter', () => {
            ring.style.width = '74px'; ring.style.height = '74px'; ring.style.opacity = '1';
            ring.style.background = 'var(--accent)'; ring.style.borderColor = 'var(--accent)'; ring.style.mixBlendMode = 'normal';
            dot.style.opacity = '0';
            if (label) label.style.opacity = '1';
          });
          el.addEventListener('mouseleave', () => {
            ring.style.width = '30px'; ring.style.height = '30px'; ring.style.opacity = '0.55';
            ring.style.background = 'transparent'; ring.style.borderColor = 'var(--accent)'; ring.style.mixBlendMode = 'var(--ring-blend)';
            dot.style.opacity = '1';
            if (label) label.style.opacity = '0';
          });
        });
        this.disposers.push(() => { window.removeEventListener('mousemove', onMove); cancelAnimationFrame(this._craf); });
      }

      initMagnetic() {
        if (this.coarse) return;
        this.root.querySelectorAll('[data-magnetic]').forEach((el) => {
          el.style.transition = 'transform .45s cubic-bezier(.16,1,.3,1)';
          el.addEventListener('mousemove', (e) => {
            const r = el.getBoundingClientRect();
            const x = e.clientX - (r.left + r.width / 2);
            const y = e.clientY - (r.top + r.height / 2);
            el.style.transform = 'translate(' + (x * 0.3) + 'px,' + (y * 0.4) + 'px)';
          });
          el.addEventListener('mouseleave', () => { el.style.transform = 'translate(0,0)'; });
        });
      }

      initFeatured() {
        if (this.coarse) return;
        const EASE = 'cubic-bezier(.16,1,.3,1)';
        this.root.querySelectorAll('.featured-case').forEach((card) => {
          const img = card.querySelector('img');
          card.style.transformStyle = 'preserve-3d';
          const reset = () => {
            card.style.transition = 'transform .6s ' + EASE + ', box-shadow .6s ' + EASE;
            card.style.transform = 'perspective(1300px) rotateX(0deg) rotateY(0deg) translateY(0)';
            card.style.boxShadow = '';
            if (img) { img.style.transition = 'transform .6s ' + EASE; img.style.transform = ''; }
          };
          card.addEventListener('pointermove', (e) => {
            const r = card.getBoundingClientRect();
            const px = (e.clientX - r.left) / r.width - 0.5;
            const py = (e.clientY - r.top) / r.height - 0.5;
            card.style.transition = 'transform .18s ease-out, box-shadow .25s ease-out';
            card.style.transform = 'perspective(1300px) rotateX(' + (-py * 3.2) + 'deg) rotateY(' + (px * 4.2) + 'deg) translateY(-5px)';
            card.style.boxShadow = '0 34px 80px -34px var(--shadow-card), 0 14px 50px -26px var(--glow-strong)';
            if (img) { img.style.transition = 'transform .18s ease-out'; img.style.transform = 'scale(1.07) translate(' + (-px * 18) + 'px,' + (-py * 18) + 'px)'; }
          });
          card.addEventListener('pointerleave', reset);
        });
      }

      initCountUp() {
        const fmt = (n) => n.toLocaleString('en-US');
        const ease = (x) => 1 - Math.pow(1 - x, 4);
        const io = new IntersectionObserver((ents) => {
          ents.forEach((en) => {
            if (!en.isIntersecting) return;
            const el = en.target;
            io.unobserve(el);
            const m = el.textContent.trim().match(/^(~)?([\d,]+)([+%x])?$/);
            if (!m) return;
            const pre = m[1] || '', target = parseInt(m[2].replace(/,/g, ''), 10), suf = m[3] || '';
            if (!isFinite(target)) return;
            const dur = 1100, t0 = performance.now();
            el.textContent = pre + '0' + suf;
            const step = (now) => {
              const p = Math.min(1, (now - t0) / dur);
              el.textContent = pre + fmt(Math.round(target * ease(p))) + suf;
              if (p < 1) requestAnimationFrame(step);
            };
            requestAnimationFrame(step);
          });
        }, { threshold: 0.6 });
        this.root.querySelectorAll('.stat-v').forEach((el) => io.observe(el));
        this.disposers.push(() => io.disconnect());
      }

      initTilt() {
        if (this.coarse) return;
        this.root.querySelectorAll('[data-tilt]').forEach((card) => {
          const reset = () => {
            card.style.transition = 'transform .6s cubic-bezier(.16,1,.3,1), box-shadow .6s cubic-bezier(.16,1,.3,1)';
            card.style.transform = 'rotateX(0deg) rotateY(0deg)';
            card.style.boxShadow = '0 18px 40px -28px var(--shadow-color)';
            const lay = card.querySelector('[data-tilt-layer]');
            if (lay) lay.style.transform = 'translateZ(0)';
          };
          card.style.transformStyle = 'preserve-3d';
          card.addEventListener('pointermove', (e) => {
            const r = card.getBoundingClientRect();
            const px = (e.clientX - r.left) / r.width - 0.5;
            const py = (e.clientY - r.top) / r.height - 0.5;
            card.style.transition = 'transform .12s linear, box-shadow .2s linear';
            card.style.transform = 'rotateX(' + (-py * 9) + 'deg) rotateY(' + (px * 11) + 'deg)';
            card.style.boxShadow = (-px * 26) + 'px ' + (-py * 22 + 24) + 'px 55px -22px var(--shadow-card)';
            const lay = card.querySelector('[data-tilt-layer]');
            if (lay) lay.style.transform = 'translateZ(45px) translate(' + (-px * 14) + 'px,' + (-py * 14) + 'px)';
          });
          card.addEventListener('pointerleave', reset);
        });
      }

      initParticles() {
        const THREE = window.THREE;
        const hero = this.root.querySelector('#hero');
        const canvas = this.root.querySelector('#hero-canvas');
        if (!hero || !canvas) return;

        if (canvas._edStop) { try { canvas._edStop(); } catch (e) {} }
        let stopped = false;

        const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true, preserveDrawingBuffer: true });
        renderer.setClearColor(0x000000, 0);
        const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
        renderer.setPixelRatio(dpr);
        this.renderer = renderer;

        let W = window.innerWidth, H = window.innerHeight;
        renderer.setSize(W, H, false);
        const cam = new THREE.OrthographicCamera(-W / 2, W / 2, H / 2, -H / 2, -1000, 1000);
        cam.position.z = 10;
        const scene = new THREE.Scene();

        const material = new THREE.ShaderMaterial({
          uniforms: { uPixelRatio: { value: dpr }, uAlpha: { value: 1.0 }, uLight: { value: 0.0 } },
          vertexShader: 'attribute float aSize; attribute vec3 aColor; varying vec3 vColor; uniform float uPixelRatio; void main(){ vColor=aColor; vec4 mv=modelViewMatrix*vec4(position,1.0); gl_PointSize=aSize*uPixelRatio; gl_Position=projectionMatrix*mv; }',
          // uLight=1 (light theme) drops the additive core-glow and lifts alpha so
          // the warm ink particles read against a bright background under normal blending.
          fragmentShader: 'precision mediump float; varying vec3 vColor; uniform float uAlpha; uniform float uLight; void main(){ vec2 c=gl_PointCoord-0.5; float d=length(c); float a=smoothstep(0.5,0.0,d); a=pow(a,1.5); if(a<0.01) discard; vec3 col=vColor*(1.0+(1.0-uLight)*0.8*pow(a,3.0)); float alpha=a*uAlpha*(1.0+uLight*0.55); gl_FragColor=vec4(col, alpha); }',
          transparent: true, depthTest: false, depthWrite: false, blending: THREE.AdditiveBlending
        });
        this.material = material;

        const FORM = 5200, AMB = 1200, N = FORM + AMB;
        const amber = this.amber, plum = [110 / 255, 48 / 255, 66 / 255];
        const col = new Float32Array(N * 3), siz = new Float32Array(N);
        const seed = new Float32Array(N), depth = new Float32Array(N), vel = new Float32Array(N * 2);
        // Per-particle class/brightness randoms are kept so a live theme swap
        // recolours the field in place instead of reshuffling it.
        const rClass = new Float32Array(N), bright = new Float32Array(N);
        for (let k = 0; k < N; k++) {
          seed[k] = Math.random();
          rClass[k] = Math.random();
          bright[k] = Math.random();
          if (k < FORM) {
            depth[k] = 1.0;
            siz[k] = (rClass[k] < 0.20 ? 4.2 + Math.random() * 3.6 : 2.2 + Math.random() * 2.2);
          } else {
            depth[k] = 0.22 + Math.random() * 0.5;
            siz[k] = 1.1 + Math.random() * 1.8;
          }
        }
        // Dark theme: bright cream/amber/plum sparks tuned for additive blending on
        // a near-black field. Light theme: warm ink tones for normal blending, since
        // additive light is invisible over a bright background.
        const paintParticles = (light) => {
          for (let k = 0; k < N; k++) {
            const r = rClass[k], b = bright[k];
            let cr, cg, cb, bb = 1;
            if (k < FORM) {
              if (!light) {
                if (r < 0.20) { cr = 1.0; cg = 0.93; cb = 0.78; bb = 1.5 + b * 0.7; }
                else if (r < 0.85) { cr = amber[0]; cg = amber[1]; cb = amber[2]; bb = 1.05 + b * 0.5; }
                else { cr = plum[0] * 1.5; cg = plum[1] * 1.5; cb = plum[2] * 1.5; bb = 0.85 + b * 0.4; }
              } else {
                if (r < 0.20) { cr = 0.62; cg = 0.40; cb = 0.16; bb = 0.95 + b * 0.25; }
                else if (r < 0.85) { cr = 0.50; cg = 0.31; cb = 0.15; bb = 0.9 + b * 0.25; }
                else { cr = 0.34; cg = 0.24; cb = 0.30; bb = 0.85 + b * 0.25; }
              }
            } else {
              if (!light) { const dim = 0.3 + b * 0.45; cr = amber[0] * dim; cg = amber[1] * dim; cb = amber[2] * dim * 0.85; }
              else { const dim = 0.45 + b * 0.35; cr = 0.52 * dim; cg = 0.36 * dim; cb = 0.20 * dim; }
            }
            col[k * 3] = cr * bb; col[k * 3 + 1] = cg * bb; col[k * 3 + 2] = cb * bb;
          }
          if (this.geo) this.geo.attributes.aColor.needsUpdate = true;
          material.blending = light ? THREE.NormalBlending : THREE.AdditiveBlending;
          material.uniforms.uLight.value = light ? 1.0 : 0.0;
          material.needsUpdate = true;
        };
        const isLight = () => document.documentElement.getAttribute('data-theme') === 'light';
        paintParticles(isLight());
        // small per-particle jitter so wrap-around targets don't overlap exactly
        const jit = new Float32Array(N * 2);
        for (let k = 0; k < N; k++) { jit[k * 2] = (Math.random() - 0.5) * 7; jit[k * 2 + 1] = (Math.random() - 0.5) * 7; }
        const shuffle = (a) => { const L = a.length / 2; for (let i = L - 1; i > 0; i--) { const j = (Math.random() * (i + 1)) | 0; const px = a[i * 2], py = a[i * 2 + 1]; a[i * 2] = a[j * 2]; a[i * 2 + 1] = a[j * 2 + 1]; a[j * 2] = px; a[j * 2 + 1] = py; } return a; };
        // 'center' = one motif in the middle (hero wordmark).
        // 'sides'  = mirror a smaller motif into the left and right gutters, so the
        //            section content stays clear in the middle.
        // push side motifs past the content container (~1120 wide) into the gutter,
        // scaling the gap with the available side room so blocks stay clear
        const sideOffset = () => { const edge = Math.min(W * 0.5, 560); return edge + Math.max(70, (W * 0.5 - edge) * 0.55); };
        let offX = sideOffset();
        const buildTargets = (pool, mode, scale) => {
          shuffle(pool);
          const L = Math.max(1, pool.length / 2), arr = new Float32Array(FORM * 2);
          for (let i = 0; i < FORM; i++) {
            if (mode === 'center') {
              const s = i % L;
              arr[i * 2] = pool[s * 2] + jit[i * 2];
              arr[i * 2 + 1] = pool[s * 2 + 1] + jit[i * 2 + 1];
            } else {
              const side = (i & 1) ? 1 : -1, s = (i >> 1) % L;
              arr[i * 2] = pool[s * 2] * scale + side * offX + jit[i * 2];
              arr[i * 2 + 1] = pool[s * 2 + 1] * scale + jit[i * 2 + 1];
            }
          }
          return arr;
        };
        // left and right get different (but paired) motifs
        const buildSides = (poolL, poolR, sl, sr) => {
          shuffle(poolL); shuffle(poolR);
          const Ll = Math.max(1, poolL.length / 2), Lr = Math.max(1, poolR.length / 2), arr = new Float32Array(FORM * 2);
          for (let i = 0; i < FORM; i++) {
            const s = i >> 1;
            if (i & 1) { const k = s % Lr; arr[i * 2] = poolR[k * 2] * sr + offX + jit[i * 2]; arr[i * 2 + 1] = poolR[k * 2 + 1] * sr + jit[i * 2 + 1]; }
            else { const k = s % Ll; arr[i * 2] = poolL[k * 2] * sl - offX + jit[i * 2]; arr[i * 2 + 1] = poolL[k * 2 + 1] * sl + jit[i * 2 + 1]; }
          }
          return arr;
        };

        // one motif per section; particles morph between them as you scroll
        const sectionKeys = ['hero', 'about', 'skills', 'experience', 'work', 'ai', 'contact'];
        let forms = [];
        const ambHome = new Float32Array(AMB * 2);
        const buildForms = () => {
          offX = sideOffset();
          // hero: particles are just a quiet scattered starfield (the name is crisp
          // solid type, NOT traced by particles); they gather into motifs on scroll
          const scatter = [];
          for (let k = 0; k < FORM; k++) scatter.push((Math.random() - 0.5) * W * 1.1, (Math.random() - 0.5) * H * 1.02);
          forms = [
            buildTargets(scatter, 'center', 1),
            buildSides(this.rasterText(['Vue'], W, H, 0.34, 1.0), this.rasterText(['React'], W, H, 0.34, 1.0), 0.46, 0.46),       // about
            buildSides(this.rasterText(['PHP'], W, H, 0.34, 1.0), this.rasterText(['TS'], W, H, 0.34, 1.0), 0.46, 0.46),          // skills
            buildSides(this.rasterText(['Laravel'], W, H, 0.34, 1.0), this.rasterText(['Symfony'], W, H, 0.34, 1.0), 0.46, 0.46), // experience
            buildSides(this.rasterText(['VALT'], W, H, 0.34, 1.0), this.rasterText(['TKM'], W, H, 0.34, 1.0), 0.46, 0.46),        // work
            buildSides(this.rasterText(['A'], W, H, 0.3, 1.0), this.rasterText(['I'], W, H, 0.3, 1.0), 0.5, 0.5),                 // ai
            buildSides(this.rasterText(['@'], W, H, 0.42, 1.0), this.rasterText(['HI'], W, H, 0.34, 1.0), 0.52, 0.5),             // contact
          ];
          for (let k = 0; k < AMB; k++) { ambHome[k * 2] = (Math.random() - 0.5) * W * 1.15; ambHome[k * 2 + 1] = (Math.random() - 0.5) * H * 1.15; }
        };
        buildForms();

        const pos = new Float32Array(N * 3);
        for (let k = 0; k < N; k++) {
          if (k < FORM) { const ang = Math.random() * Math.PI * 2, rad = Math.max(W, H) * (0.5 + Math.random() * 0.8); pos[k * 3] = Math.cos(ang) * rad; pos[k * 3 + 1] = Math.sin(ang) * rad; }
          else { pos[k * 3] = ambHome[(k - FORM) * 2]; pos[k * 3 + 1] = ambHome[(k - FORM) * 2 + 1]; }
          pos[k * 3 + 2] = 0;
        }
        const geo = new THREE.BufferGeometry();
        geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
        geo.setAttribute('aColor', new THREE.BufferAttribute(col, 3));
        geo.setAttribute('aSize', new THREE.BufferAttribute(siz, 1));
        const points = new THREE.Points(geo, material);
        points.frustumCulled = false;
        scene.add(points);
        this.geo = geo;

        // Recolour + re-blend the field when the user flips the theme.
        const onTheme = () => paintParticles(isLight());
        window.addEventListener('themechange', onTheme);
        this.disposers.push(() => window.removeEventListener('themechange', onTheme));

        // anchor each formation to the scroll position where its section sits centered
        let anchors = new Array(sectionKeys.length).fill(0);
        const computeAnchors = () => {
          const sy = window.scrollY || window.pageYOffset || 0;
          // furthest the page can scroll — clamp anchors so a short last section
          // (contact + footer shorter than the viewport) stays reachable, otherwise
          // its motif never forms and the previous one stays stuck on screen
          const maxScroll = Math.max(0, document.documentElement.scrollHeight - H);
          for (let i = 0; i < sectionKeys.length; i++) {
            const el = this.root.querySelector('#' + sectionKeys[i]);
            if (!el) { anchors[i] = i ? anchors[i - 1] : 0; continue; }
            const r = el.getBoundingClientRect();
            anchors[i] = Math.min(maxScroll, Math.max(0, r.top + sy - H * 0.2));
          }
          anchors[0] = 0;
        };
        computeAnchors();
        setTimeout(computeAnchors, 1200);
        this._recompute = () => { buildForms(); computeAnchors(); };

        const nameEl = this.root.querySelector('#hero-name');
        if (nameEl) { nameEl.style.transition = 'none'; }

        const mouse = { x: 0, y: 0, active: false };
        const onMove = (e) => {
          mouse.x = e.clientX - W / 2;
          mouse.y = -(e.clientY - H / 2);
          mouse.active = true;
        };
        const onLeave = () => { mouse.active = false; };
        window.addEventListener('mousemove', onMove);
        window.addEventListener('mouseout', onLeave);

        const R = Math.min(W, H) * 0.18;
        const idleAmp = this.idleOn ? 2.0 : 0;
        const t0 = performance.now();
        const loop = () => {
          if (stopped) return;
          this.raf = requestAnimationFrame(loop);
          if (document.hidden) return;
          const time = (performance.now() - t0) / 1000;
          const pos = this.geo.attributes.position.array;
          const mx = mouse.x, my = mouse.y, active = mouse.active;
          const rr = R * R;
          // which two section motifs are we between, and how far through?
          const curY = window.scrollY || window.pageYOffset || 0;
          let f = 0;
          while (f < anchors.length - 1 && curY >= anchors[f + 1]) f++;
          let t = 0;
          if (f < anchors.length - 1) { const span = (anchors[f + 1] - anchors[f]) || 1; t = Math.max(0, Math.min(1, (curY - anchors[f]) / span)); }
          // hold the motif while its section is in view, morph only near the end of the gap
          const tm = Math.max(0, Math.min(1, (t - 0.6) / 0.4));
          const te = tm * tm * (3 - 2 * tm);
          const A = forms[f], B = forms[Math.min(f + 1, forms.length - 1)];
          // dim the field once you leave the hero so body text stays readable
          const heroFade = Math.max(0, Math.min(1, curY / (H * 0.6)));
          this.material.uniforms.uAlpha.value = 0.42 + heroFade * 0.18;
          if (nameEl) nameEl.style.opacity = (1 - Math.min(1, heroFade * 1.35)).toFixed(3);
          const par = active ? 0.03 : 0;
          for (let i = 0; i < N; i++) {
            const s = seed[i], dp = depth[i];
            const pmx = mx * par * dp, pmy = my * par * dp;
            let tx, ty, repel;
            if (i < FORM) {
              // formation particle: morph from motif A -> motif B as you scroll
              const ax2 = A[i * 2], ay2 = A[i * 2 + 1];
              const gx = ax2 + (B[i * 2] - ax2) * te;
              const gy = ay2 + (B[i * 2 + 1] - ay2) * te;
              tx = gx + Math.sin(time * 0.5 + s * 6.28) * idleAmp + pmx;
              ty = gy + Math.cos(time * 0.45 + s * 6.28) * idleAmp + pmy;
              repel = 1;
            } else {
              // ambient depth field: slow drift, parallax by depth
              const hx = ambHome[(i - FORM) * 2], hy = ambHome[(i - FORM) * 2 + 1];
              tx = hx + Math.sin(time * 0.16 + s * 6.28) * 9.0 + pmx;
              ty = hy + Math.cos(time * 0.13 + s * 6.28) * 9.0 + pmy;
              repel = 0;
            }
            const px = pos[i * 3], py = pos[i * 3 + 1];
            const dxt = tx - px, dyt = ty - py;
            let kk = 0.05 + s * 0.025;
            // far from target (e.g. a nav-jump skipped several sections) -> snap into
            // the formation fast; close in -> stay gentle so the morph reads smooth
            if (dxt * dxt + dyt * dyt > 9000) kk *= 2.4;
            let ax = dxt * kk, ay = dyt * kk;
            if (active && repel > 0) {
              const ddx = px - mx, ddy = py - my, d2 = ddx * ddx + ddy * ddy;
              if (d2 < rr) {
                const d = Math.sqrt(d2) || 0.001;
                const ff = (1 - d / R), fff = ff * ff * 7.0;
                const ux = ddx / d, uy = ddy / d;
                ax += ux * fff - uy * fff * 0.5;   // repel + orbital swirl
                ay += uy * fff + ux * fff * 0.5;
              }
            }
            const vx = (vel[i * 2] + ax) * 0.85, vy = (vel[i * 2 + 1] + ay) * 0.85;
            vel[i * 2] = vx; vel[i * 2 + 1] = vy;
            pos[i * 3] = px + vx; pos[i * 3 + 1] = py + vy;
          }
          this.geo.attributes.position.needsUpdate = true;
          renderer.render(scene, cam);
        };
        loop();

        let rt;
        const onResize = () => {
          clearTimeout(rt);
          rt = setTimeout(() => {
            W = window.innerWidth; H = window.innerHeight;
            renderer.setSize(W, H, false);
            cam.left = -W / 2; cam.right = W / 2; cam.top = H / 2; cam.bottom = -H / 2;
            cam.updateProjectionMatrix();
            this._recompute();
          }, 220);
        };
        window.addEventListener('resize', onResize);

        const stop = () => {
          stopped = true;
          cancelAnimationFrame(this.raf);
          window.removeEventListener('mousemove', onMove);
          window.removeEventListener('mouseout', onLeave);
          window.removeEventListener('resize', onResize);
          try { points.geometry.dispose(); } catch (e) {}
          try { material.dispose(); } catch (e) {}
          try { renderer.dispose(); } catch (e) {}
          if (canvas._edStop === stop) canvas._edStop = null;
        };
        canvas._edStop = stop;
        this._stop = stop;
        this.disposers.push(stop);
      }

      // Sample the wordmark at the real <h1> box so the particle aura lines up
      // exactly with the crisp solid type sitting on top of it.
      heroNamePool(W, H) {
        const nameEl = this.root.querySelector('#hero-name');
        const c = document.createElement('canvas'); c.width = W; c.height = H;
        const x = c.getContext('2d');
        x.clearRect(0, 0, W, H);
        x.fillStyle = '#fff'; x.textAlign = 'center'; x.textBaseline = 'middle';
        try { x.letterSpacing = '-0.035em'; } catch (e) {}
        const setFont = (s) => { x.font = '700 ' + s + 'px "Bricolage Grotesque", sans-serif'; };
        let cx = W / 2, cy = H * 0.44, fs;
        if (nameEl) {
          const nr = nameEl.getBoundingClientRect();
          cx = (nr.left + nr.right) / 2; cy = (nr.top + nr.bottom) / 2;
          fs = parseFloat(getComputedStyle(nameEl).fontSize) || Math.min(H * 0.22, W * 0.16);
        } else { fs = Math.min(H * 0.22, W * 0.16); }
        setFont(fs);
        const maxW = W * 0.86, w = x.measureText('DADASHOV').width;
        if (w > maxW) { fs = fs * maxW / w; setFont(fs); }
        const lh = fs * 0.9;
        x.fillText('ELDAR', cx, cy - lh * 0.5);
        x.fillText('DADASHOV', cx, cy + lh * 0.5);
        const data = x.getImageData(0, 0, W, H).data;
        const gap = Math.max(3, Math.round(W / 340));
        const out = [];
        for (let yy = 0; yy < H; yy += gap)
          for (let xx = 0; xx < W; xx += gap)
            if (data[(yy * W + xx) * 4 + 3] > 120) out.push(xx - W / 2, H / 2 - yy);
        return out;
      }

      // Rasterize centered text into a pool of (x,y) points, centered & y-up.
      rasterText(lines, W, H, widthFrac, lhFrac) {
        const c = document.createElement('canvas'); c.width = W; c.height = H;
        const x = c.getContext('2d');
        x.clearRect(0, 0, W, H);
        x.fillStyle = '#fff'; x.textAlign = 'center'; x.textBaseline = 'middle';
        try { x.letterSpacing = '-0.03em'; } catch (e) {}
        const setFont = (s) => { x.font = '700 ' + s + 'px "Bricolage Grotesque", sans-serif'; };
        const cx = W / 2, cy = H * 0.44;
        let fs = Math.min(H * 0.34, W * 0.2);
        setFont(fs);
        let widest = 1;
        for (const ln of lines) widest = Math.max(widest, x.measureText(ln).width);
        const maxW = W * widthFrac;
        if (widest > maxW) { fs = fs * maxW / widest; setFont(fs); }
        const lh = fs * lhFrac;
        const start = cy - lh * (lines.length - 1) / 2;
        for (let i = 0; i < lines.length; i++) x.fillText(lines[i], cx, start + i * lh);
        const data = x.getImageData(0, 0, W, H).data;
        const gap = Math.max(3, Math.round(W / 320));
        const out = [];
        for (let yy = 0; yy < H; yy += gap)
          for (let xx = 0; xx < W; xx += gap)
            if (data[(yy * W + xx) * 4 + 3] > 120) out.push(xx - W / 2, H / 2 - yy);
        return out;
      }

      // Three clearly separated layers, narrowing upward — "the stack".
      genStack(W, H) {
        const out = [];
        const bw = Math.min(W * 0.4, 520), bh = Math.min(H * 0.072, 62), gap = bh * 2.0;
        const nb = 3, total = (nb - 1) * gap, step = Math.max(4, bw / 120);
        for (let b = 0; b < nb; b++) {
          const yc = total / 2 - b * gap, w = bw * (1 - b * 0.16);
          for (let yy = -bh / 2; yy <= bh / 2; yy += 4)
            for (let xx = -w / 2; xx <= w / 2; xx += step) out.push(xx, yc + yy);
        }
        return out;
      }

      // Rising bar chart — "work that moved a number".
      genChart(W, H) {
        const out = [];
        const nb = 7, bw = Math.min(W * 0.058, 64), gap = bw * 1.7;
        const totalW = (nb - 1) * gap, baseY = -H * 0.17, step = Math.max(4, bw / 12);
        for (let b = 0; b < nb; b++) {
          const xc = -totalW / 2 + b * gap;
          const hb = H * 0.05 + (b / (nb - 1)) * H * 0.32;
          for (let yy = 0; yy <= hb; yy += 5)
            for (let xx = -bw / 2; xx <= bw / 2; xx += step) out.push(xc + xx, baseY + yy);
        }
        return out;
      }

      // A rising growth curve — paired with the chart on the experience block.
      genTrend(W, H) {
        const out = [];
        const w = Math.min(W * 0.3, 420), h = Math.min(H * 0.3, 280), n = 80;
        for (let i = 0; i < n; i++) {
          const t = i / (n - 1), x = -w / 2 + t * w, y = -h / 2 + t * t * h;
          for (let k = -2; k <= 2; k++) out.push(x, y + k * 5);
        }
        return out;
      }

      // Grid of cards — "selected work".
      genGrid(W, H) {
        const out = [];
        const cols = 3, rows = 2, cw = Math.min(W * 0.15, 200), ch = cw * 0.64;
        const gx = cw * 1.32, gy = ch * 1.5, tw = (cols - 1) * gx, th = (rows - 1) * gy;
        const sx = Math.max(5, cw / 26), sy = Math.max(5, ch / 18);
        for (let r = 0; r < rows; r++)
          for (let ci = 0; ci < cols; ci++) {
            const xc = -tw / 2 + ci * gx, yc = th / 2 - r * gy;
            for (let yy = -ch / 2; yy <= ch / 2; yy += sy)
              for (let xx = -cw / 2; xx <= cw / 2; xx += sx) out.push(xc + xx, yc + yy);
          }
        return out;
      }
    }

    const __start = () => { try { new Portfolio().mount(); } catch (e) { console.warn(e); } };
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', __start);
    else __start();
  </script>
</Base>
