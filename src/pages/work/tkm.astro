---
import Base from "../../layouts/Base.astro";
import { tkm as cs } from "../../data/content";

const creativeWork = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: cs.name,
  headline: cs.tagline,
  description: cs.summary,
  url: new URL(`/work/${cs.slug}`, Astro.site).href,
  keywords: cs.stack.join(", "),
  author: { "@type": "Person", name: "Eldar Dadashov" },
};

/* Orchestration flow shown in the "under the hood" section. Abstract by design:
   no real accounts, marketplace data, proxy provider or credentials. */
const flow = [
  {
    n: "01",
    title: "Request a session",
    detail: "The desktop application asks the API for a session: identity, sticky proxy and a region-pinned IP, under an open-lock so two instances never collide.",
  },
  {
    n: "02",
    title: "Spin an anti-detect browser",
    detail: "It launches a real Chrome with the account's deterministic fingerprint over CDP, restores state and warms the proxy before any real work.",
  },
  {
    n: "03",
    title: "Operate and intercept",
    detail: "Work happens in a real browser; the desktop application intercepts the relevant calls over CDP and streams structured hints back to the API.",
  },
  {
    n: "04",
    title: "Normalize and persist",
    detail: "The API normalizes those hints into a clean order, position and pickup-point model in PostgreSQL through Prisma.",
  },
  {
    n: "05",
    title: "Sync and reconcile",
    detail: "Scheduled BullMQ workers reconcile later state back to the right record with a FIFO matching pass, keeping the data consistent.",
  },
];

const antidetect = [
  { k: "Fingerprint", v: "Deterministic per-account seed over CDP, realistic version split, 5-day rotation + cooling-off." },
  { k: "Proxies", v: "Sticky residential & mobile sessions, one unique IP per account, IP history tracked." },
  { k: "GeoIP", v: "MaxMind region pinning so an account's IP stays geographically consistent." },
  { k: "Warm-up", v: "A narrow warm-up window prioritizes active accounts before real operations." },
  { k: "Recovery", v: "Logout detection and re-auth before work, instead of failing mid-task." },
  { k: "Throttle", v: "Bounded concurrency, retries and rate-limit control across ~2,500 sessions." },
];
---

<Base title={`${cs.name} — case study — Eldar Dadashov`} description={cs.tagline} ogType="article" jsonLd={[creativeWork]}>
  <div style="--bg:oklch(0.17 0.015 50);--surface:oklch(0.22 0.02 50);--text:oklch(0.93 0.012 85);--dim:oklch(0.68 0.015 75);--accent:oklch(0.74 0.17 55);--line:oklch(0.32 0.02 50);background:var(--bg);color:var(--text);font-family:'Hanken Grotesk',sans-serif;min-height:100vh;position:relative;overflow-x:hidden">

    <header style="position:sticky;top:0;z-index:40;display:flex;align-items:center;justify-content:space-between;padding:18px clamp(20px,5vw,40px);font-family:'JetBrains Mono',monospace;font-size:12.5px;letter-spacing:.08em;background:color-mix(in oklch, var(--bg) 86%, transparent);backdrop-filter:blur(8px);border-bottom:1px solid var(--line)">
      <a href="/" class="nav-link" style="color:var(--dim)">← BACK</a>
      <span style="color:var(--accent)">{cs.name} / CASE STUDY</span>
    </header>

    <section style="position:relative;max-width:1240px;margin:0 auto;padding:clamp(44px,7vh,90px) clamp(20px,5vw,40px) clamp(30px,5vh,56px);overflow:hidden">
      <div aria-hidden="true" style="position:absolute;top:-8%;right:-6%;width:62%;height:540px;background:radial-gradient(closest-side, oklch(0.74 0.17 55 / 0.18), transparent 70%);filter:blur(18px);pointer-events:none;z-index:0"></div>

      <div style="position:relative;z-index:1;display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,440px),1fr));gap:clamp(34px,5vw,62px);align-items:center">
        <div>
          <svg viewBox="0 0 316 395" aria-label="TKM logo" style="width:auto;height:48px;color:var(--text);display:block;margin-bottom:22px;filter:drop-shadow(0 6px 16px rgba(0,0,0,0.5))">
            <path d="M157.643 39.6786L280.987 110.875L315.351 91.032L157.643 0L0 91.032L34.356 110.871L157.643 39.6786Z" fill="currentColor" opacity="0.95"></path>
            <path d="M157.738 212.664H157.674V212.483L0.0303955 121.452V303.515L157.674 394.546V394.727L315.381 303.695V121.632L157.738 212.664Z" fill="currentColor" opacity="0.62"></path>
          </svg>
          <div style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:.12em;color:var(--accent);text-transform:uppercase">{cs.kicker}</div>
          <h1 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:clamp(46px,8vw,116px);line-height:0.9;letter-spacing:-0.035em;margin:16px 0 16px;overflow-wrap:break-word">{cs.name}</h1>
          <p style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(21px,3vw,34px);line-height:1.12;letter-spacing:-0.02em;color:var(--text);max-width:20ch">{cs.tagline}</p>
          <p style="font-family:'Hanken Grotesk',sans-serif;font-size:clamp(16px,1.4vw,19px);line-height:1.62;color:var(--dim);max-width:56ch;margin-top:22px">{cs.summary}</p>
        </div>

        <!-- Architecture diagram (no screenshots: this project shows no real UI or data) -->
        <div style="position:relative">
          <svg class="arch" viewBox="0 0 560 620" role="img" aria-label="Architecture: a web console and many desktop applications talk to a NestJS API over one OpenAPI-typed contract, backed by PostgreSQL and Redis." style="width:100%;height:auto;display:block;overflow:visible;filter:drop-shadow(0 30px 50px rgba(0,0,0,0.45))">
            <!-- connectors -->
            <g fill="none" stroke="var(--accent)" stroke-width="1.6" opacity="0.6">
              <path class="wire" d="M140,116 L140,176" />
              <path class="wire" d="M420,116 L420,176" />
              <path class="wire" d="M280,216 L280,280" stroke-width="2" opacity="0.85" />
              <path class="wire" d="M200,396 L200,440 L150,440 L150,476" />
              <path class="wire" d="M360,396 L360,440 L410,440 L410,476" />
            </g>
            <g fill="var(--accent)">
              <circle cx="280" cy="280" r="3.2" />
              <circle cx="150" cy="476" r="3" />
              <circle cx="410" cy="476" r="3" />
            </g>

            <!-- Web console -->
            <g>
              <rect x="24" y="24" width="232" height="92" rx="11" fill="var(--surface)" stroke="var(--line)" />
              <circle cx="46" cy="52" r="3.4" fill="var(--accent)" />
              <text x="58" y="57" font-family="'Bricolage Grotesque',sans-serif" font-weight="600" font-size="19" fill="var(--text)">Web console</text>
              <text x="46" y="84" font-family="'JetBrains Mono',monospace" font-size="11.5" letter-spacing="0.04em" fill="var(--dim)">React · MUI · TanStack</text>
            </g>

            <!-- Desktop application (runs on N operator machines) -->
            <g>
              <rect x="316" y="12" width="232" height="92" rx="11" fill="var(--surface)" stroke="var(--line)" opacity="0.35" />
              <rect x="310" y="18" width="232" height="92" rx="11" fill="var(--surface)" stroke="var(--line)" opacity="0.65" />
              <rect x="304" y="24" width="232" height="92" rx="11" fill="var(--surface)" stroke="var(--line)" />
              <circle cx="326" cy="52" r="3.4" fill="var(--accent)" />
              <text x="338" y="57" font-family="'Bricolage Grotesque',sans-serif" font-weight="600" font-size="18" fill="var(--text)">Desktop application</text>
              <text x="326" y="84" font-family="'JetBrains Mono',monospace" font-size="11.5" letter-spacing="0.04em" fill="var(--dim)">Electron · Patchright · ×N</text>
            </g>

            <!-- Typed contract -->
            <g>
              <rect x="70" y="176" width="420" height="40" rx="20" fill="color-mix(in oklch, var(--accent) 14%, var(--surface))" stroke="var(--accent)" stroke-opacity="0.55" />
              <text x="280" y="201" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-size="12.5" letter-spacing="0.08em" fill="var(--accent)">OpenAPI typed contract</text>
            </g>

            <!-- API orchestrator -->
            <g>
              <rect x="120" y="280" width="320" height="116" rx="13" fill="var(--surface)" stroke="var(--accent)" stroke-opacity="0.85" stroke-width="1.4" />
              <text x="280" y="332" text-anchor="middle" font-family="'Bricolage Grotesque',sans-serif" font-weight="700" font-size="26" fill="var(--text)">NestJS API</text>
              <text x="280" y="360" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-size="12" letter-spacing="0.05em" fill="var(--dim)">orchestration · BullMQ workers</text>
            </g>

            <!-- PostgreSQL -->
            <g>
              <rect x="40" y="476" width="220" height="92" rx="11" fill="var(--surface)" stroke="var(--line)" />
              <circle cx="62" cy="504" r="3.4" fill="var(--accent)" />
              <text x="74" y="509" font-family="'Bricolage Grotesque',sans-serif" font-weight="600" font-size="18" fill="var(--text)">PostgreSQL</text>
              <text x="62" y="536" font-family="'JetBrains Mono',monospace" font-size="11.5" fill="var(--dim)">Prisma · normalized</text>
            </g>

            <!-- Redis / BullMQ -->
            <g>
              <rect x="300" y="476" width="220" height="92" rx="11" fill="var(--surface)" stroke="var(--line)" />
              <circle cx="322" cy="504" r="3.4" fill="var(--accent)" />
              <text x="334" y="509" font-family="'Bricolage Grotesque',sans-serif" font-weight="600" font-size="18" fill="var(--text)">Redis</text>
              <text x="322" y="536" font-family="'JetBrains Mono',monospace" font-size="11.5" fill="var(--dim)">queues · sessions</text>
            </g>
          </svg>
        </div>
      </div>

      <div style="position:relative;z-index:1;display:flex;flex-wrap:wrap;gap:clamp(28px,6vw,72px);margin-top:clamp(30px,4vh,48px);padding-top:32px;border-top:1px solid var(--line)">
        {cs.stats.map((s) => (
          <div>
            <div style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:clamp(28px,4vw,46px);line-height:1;letter-spacing:-0.02em;color:var(--text)">{s.value}</div>
            <div style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.08em;color:var(--dim);text-transform:uppercase;margin-top:8px">{s.label}</div>
          </div>
        ))}
      </div>

      <div style="position:relative;z-index:1;display:flex;flex-wrap:wrap;gap:10px;margin-top:30px">
        {cs.stack.map((t) => (
          <span style="font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--text);background:var(--surface);border:1px solid var(--line);padding:6px 12px;border-radius:4px">{t}</span>
        ))}
      </div>
    </section>

    <section style="max-width:1080px;margin:0 auto;padding:clamp(70px,11vh,140px) clamp(20px,5vw,40px) clamp(50px,7vh,90px)">
      <div style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:.14em;color:var(--accent);margin-bottom:14px">/ my contribution</div>
      <h2 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:600;font-size:clamp(30px,4.6vw,58px);line-height:1.04;letter-spacing:-0.02em;max-width:18ch;margin-bottom:50px">What I built.</h2>

      <div style="display:flex;flex-direction:column">
        {cs.contributions.map((group) => (
          <div style="display:grid;grid-template-columns:minmax(0,200px) 1fr;gap:clamp(18px,4vw,56px);align-items:start;border-top:1px solid var(--line);padding:clamp(30px,4.5vh,48px) 0">
            <div style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:.1em;color:var(--accent);text-transform:uppercase;padding-top:6px">{group.theme}</div>
            <div style="display:flex;flex-direction:column;gap:clamp(26px,3.5vh,38px)">
              {group.items.map((item) => (
                <div>
                  <h3 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:600;font-size:clamp(19px,2.3vw,26px);line-height:1.18;color:var(--text);max-width:32ch">{item.title}</h3>
                  <p style="font-family:'Hanken Grotesk',sans-serif;font-size:clamp(15.5px,1.4vw,18px);line-height:1.6;color:var(--dim);max-width:64ch;margin-top:10px">{item.detail}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section style="max-width:1080px;margin:0 auto;padding:clamp(40px,6vh,80px) clamp(20px,5vw,40px)">
      <div style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:.14em;color:var(--accent);margin-bottom:14px">/ the product</div>
      <h2 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:600;font-size:clamp(28px,4vw,48px);line-height:1.06;letter-spacing:-0.02em;max-width:20ch;margin-bottom:18px">What TKM does.</h2>
      <p style="font-family:'Hanken Grotesk',sans-serif;font-size:clamp(15px,1.3vw,18px);color:var(--dim);margin-bottom:42px">Built for {cs.sectors.join(", ")}.</p>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:2px;background:var(--line);border:1px solid var(--line);border-radius:8px;overflow:hidden">
        {cs.product.map((f) => (
          <div style="background:var(--bg);padding:28px 26px 32px">
            <h3 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:600;font-size:clamp(18px,1.9vw,22px);line-height:1.2;color:var(--text);max-width:22ch">{f.title}</h3>
            <p style="font-family:'Hanken Grotesk',sans-serif;font-size:15.5px;line-height:1.55;color:var(--dim);margin-top:12px">{f.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Under the hood: a designed flow, not screenshots (no real data is shown) -->
    <section style="max-width:1080px;margin:0 auto;padding:clamp(60px,9vh,120px) clamp(20px,5vw,40px)">
      <div style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:.14em;color:var(--accent);margin-bottom:14px">/ under the hood</div>
      <h2 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:600;font-size:clamp(28px,4vw,48px);line-height:1.06;letter-spacing:-0.02em;max-width:22ch;margin-bottom:14px">One session, end to end.</h2>
      <p style="font-family:'Hanken Grotesk',sans-serif;font-size:clamp(15px,1.3vw,18px);line-height:1.6;color:var(--dim);max-width:62ch;margin-bottom:46px">There are no screenshots here on purpose — this is a private NDA project and nothing real is shown. So here is the engineering instead: what happens from the moment the desktop application asks for a session to the data landing clean in Postgres.</p>

      <div style="display:flex;flex-direction:column;border-top:1px solid var(--line)">
        {flow.map((step) => (
          <div style="display:grid;grid-template-columns:minmax(0,64px) 1fr;gap:clamp(16px,3vw,40px);align-items:start;border-bottom:1px solid var(--line);padding:clamp(22px,3vh,32px) 0">
            <div style="font-family:'JetBrains Mono',monospace;font-size:15px;letter-spacing:.04em;color:var(--accent);padding-top:4px">{step.n}</div>
            <div>
              <h3 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:600;font-size:clamp(18px,2.1vw,24px);line-height:1.16;color:var(--text)">{step.title}</h3>
              <p style="font-family:'Hanken Grotesk',sans-serif;font-size:clamp(15px,1.3vw,17.5px);line-height:1.58;color:var(--dim);max-width:70ch;margin-top:9px">{step.detail}</p>
            </div>
          </div>
        ))}
      </div>

      <div style="margin-top:clamp(46px,7vh,80px)">
        <div style="font-family:'JetBrains Mono',monospace;font-size:12.5px;letter-spacing:.1em;color:var(--accent);text-transform:uppercase;margin-bottom:22px">The anti-detect stack</div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:2px;background:var(--line);border:1px solid var(--line);border-radius:8px;overflow:hidden">
          {antidetect.map((a) => (
            <div style="background:var(--bg);padding:24px 22px 26px">
              <div style="display:flex;align-items:center;gap:9px"><span style="width:7px;height:7px;border-radius:50%;background:var(--accent);flex-shrink:0"></span><span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:600;font-size:17px;color:var(--text)">{a.k}</span></div>
              <p style="font-family:'Hanken Grotesk',sans-serif;font-size:14.5px;line-height:1.5;color:var(--dim);margin-top:11px">{a.v}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section style="max-width:1080px;margin:0 auto;padding:clamp(50px,7vh,90px) clamp(20px,5vw,40px) clamp(80px,12vh,140px)">
      {cs.note && (
        <p style="font-family:'Hanken Grotesk',sans-serif;font-size:14px;line-height:1.6;color:var(--dim);max-width:62ch;margin-bottom:22px">{cs.note}</p>
      )}
      <div style="display:flex;flex-wrap:wrap;gap:14px;align-items:center">
        <a href="/#work" class="nav-link" style="font-family:'JetBrains Mono',monospace;font-size:12.5px;letter-spacing:.08em;color:var(--accent);margin-left:auto">← ALL WORK</a>
      </div>
    </section>

    <footer style="max-width:1280px;margin:0 auto;padding:30px clamp(20px,5vw,40px) 48px;display:flex;flex-wrap:wrap;gap:14px;justify-content:space-between;font-family:'JetBrains Mono',monospace;font-size:11.5px;letter-spacing:.1em;color:var(--dim);text-transform:uppercase;border-top:1px solid var(--line)">
      <span>Eldar Dadashov</span>
      <span>TKM · Browser-automation platform</span>
      <span>© 2026</span>
    </footer>

  </div>

  <style>
    .arch .wire {
      stroke-dasharray: 5 7;
      animation: arch-flow 1.1s linear infinite;
    }
    @media (prefers-reduced-motion: reduce) {
      .arch .wire { animation: none; }
    }
    @keyframes arch-flow {
      to { stroke-dashoffset: -12; }
    }
  </style>
</Base>
